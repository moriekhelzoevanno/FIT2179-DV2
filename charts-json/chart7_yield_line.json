{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 260,
  "data": {
    "url": "data/crop_yield_slim.json"
  },
  "transform": [
    {
      "filter": "datum.crop === 'Wheat' && datum.state === 'Australia'"
    },
    {
      "calculate": "toNumber(substring(datum.year,0,4))",
      "as": "year_num"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "area",
        "color": "#E69F00",
        "opacity": 0.12,
        "line": false,
        "clip": true
      },
      "encoding": {
        "x": {
          "field": "year_num",
          "type": "quantitative"
        },
        "y": {
          "field": "yield_t_ha",
          "type": "quantitative"
        }
      }
    },
    {
      "mark": {
        "type": "line",
        "color": "#E69F00",
        "strokeWidth": 2.5,
        "clip": true
      },
      "encoding": {
        "x": {
          "field": "year_num",
          "type": "quantitative",
          "axis": {
            "title": "Year",
            "format": "d",
            "tickCount": 8
          },
          "scale": {
            "domain": [
              1990,
              2025
            ]
          }
        },
        "y": {
          "field": "yield_t_ha",
          "type": "quantitative",
          "axis": {
            "title": "Yield (t/ha)"
          }
        },
        "tooltip": [
          {
            "field": "year",
            "type": "nominal",
            "title": "Season"
          },
          {
            "field": "yield_t_ha",
            "type": "quantitative",
            "title": "Yield (t/ha)",
            "format": ".2f"
          },
          {
            "field": "area_kha",
            "type": "quantitative",
            "title": "Area planted ('000 ha)",
            "format": ",.0f"
          },
          {
            "field": "prod_kt",
            "type": "quantitative",
            "title": "Production (kt)",
            "format": ",.0f"
          }
        ]
      }
    },
    {
      "data": {
        "values": [
          {
            "year_num": 2002,
            "label": "2002–03 drought",
            "label_y": 3.3
          },
          {
            "year_num": 2006,
            "label": "2006–07 drought",
            "label_y": 2.9
          }
        ]
      },
      "layer": [
        {
          "mark": {
            "type": "rule",
            "strokeDash": [
              4,
              3
            ],
            "color": "#D55E00",
            "strokeWidth": 1.3
          },
          "encoding": {
            "x": {
              "field": "year_num",
              "type": "quantitative"
            }
          }
        },
        {
          "mark": {
            "type": "text",
            "dx": 5,
            "align": "left",
            "color": "#D55E00",
            "fontSize": 9.5,
            "fontStyle": "italic"
          },
          "encoding": {
            "x": {
              "field": "year_num",
              "type": "quantitative"
            },
            "y": {
              "field": "label_y",
              "type": "quantitative"
            },
            "text": {
              "field": "label",
              "type": "nominal"
            }
          }
        }
      ]
    }
  ],
  "config": {
    "background": null,
    "font": "DM Sans",
    "axis": {
      "labelFont": "DM Sans",
      "titleFont": "DM Sans",
      "labelFontSize": 12,
      "titleFontSize": 13,
      "gridColor": "#e8e0d4",
      "gridOpacity": 0.7,
      "domainColor": "#c8bfb0",
      "tickColor": "#c8bfb0",
      "labelColor": "#6b6a62",
      "titleColor": "#3a3a35"
    },
    "legend": {
      "labelFont": "DM Sans",
      "titleFont": "DM Sans",
      "labelFontSize": 12,
      "titleFontSize": 13,
      "labelColor": "#6b6a62",
      "titleColor": "#3a3a35"
    },
    "title": {
      "font": "Playfair Display",
      "fontSize": 14,
      "color": "#1a2e24"
    },
    "view": {
      "stroke": null
    }
  }
}
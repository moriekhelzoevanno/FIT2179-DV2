{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 270,
  "padding": {
    "top": 5,
    "right": 10,
    "bottom": 5,
    "left": 5
  },
  "data": {
    "url": "data/farmers_terms_of_trade.json"
  },
  "transform": [
    {
      "calculate": "toNumber(substring(datum.year,0,4))",
      "as": "year_num"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "rule",
        "strokeDash": [
          5,
          4
        ],
        "color": "#c8bfb0",
        "strokeWidth": 1
      },
      "data": {
        "values": [
          {
            "ref": 100
          }
        ]
      },
      "encoding": {
        "y": {
          "field": "ref",
          "type": "quantitative"
        }
      }
    },
    {
      "mark": {
        "type": "text",
        "text": "Index = 100 (2025–26)",
        "dx": 10,
        "dy": -8,
        "align": "left",
        "color": "#b0a898",
        "fontSize": 8.5,
        "fontStyle": "italic"
      },
      "data": {
        "values": [
          {
            "year_num": 1994,
            "ref": 100
          }
        ]
      },
      "encoding": {
        "x": {
          "field": "year_num",
          "type": "quantitative"
        },
        "y": {
          "field": "ref",
          "type": "quantitative"
        }
      }
    },
    {
      "mark": {
        "type": "line",
        "strokeWidth": 2.2,
        "point": false
      },
      "encoding": {
        "x": {
          "field": "year_num",
          "type": "quantitative",
          "axis": {
            "title": "Year",
            "format": "d",
            "tickCount": 8
          },
          "scale": {
            "zero": false
          }
        },
        "y": {
          "field": "value",
          "type": "quantitative",
          "axis": {
            "title": "Index (2025–26 = 100)"
          }
        },
        "color": {
          "field": "series",
          "type": "nominal",
          "scale": {
            "domain": [
              "Terms of trade",
              "Prices received",
              "Prices paid"
            ],
            "range": [
              "#0072B2",
              "#E69F00",
              "#D55E00"
            ]
          },
          "legend": null
        },
        "tooltip": [
          {
            "field": "year",
            "type": "nominal",
            "title": "Year"
          },
          {
            "field": "series",
            "type": "nominal",
            "title": "Series"
          },
          {
            "field": "value",
            "type": "quantitative",
            "title": "Index",
            "format": ".1f"
          }
        ]
      }
    }
  ],
  "config": {
    "background": null,
    "font": "DM Sans",
    "axis": {
      "labelFont": "DM Sans",
      "titleFont": "DM Sans",
      "labelFontSize": 12,
      "titleFontSize": 13,
      "gridColor": "#e8e0d4",
      "gridOpacity": 0.7,
      "domainColor": "#c8bfb0",
      "tickColor": "#c8bfb0",
      "labelColor": "#6b6a62",
      "titleColor": "#3a3a35"
    },
    "legend": {
      "labelFont": "DM Sans",
      "titleFont": "DM Sans",
      "labelFontSize": 12,
      "titleFontSize": 13,
      "labelColor": "#6b6a62",
      "titleColor": "#3a3a35"
    },
    "title": {
      "font": "Playfair Display",
      "fontSize": 14,
      "color": "#1a2e24"
    },
    "view": {
      "stroke": null
    }
  }
}
{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 290,
  "data": {
    "url": "data/crop_yield_slim.json"
  },
  "params": [
    {
      "name": "season_filter",
      "value": "All"
    }
  ],
  "transform": [
    {
      "filter": "datum.crop === 'Wheat' && datum.state === 'Australia'"
    },
    {
      "calculate": "toNumber(substring(datum.year,0,4))",
      "as": "year_num"
    },
    {
      "calculate": "datum.yield_t_ha < 1.6 ? 'Drought year' : 'Good season'",
      "as": "season_type"
    },
    {
      "filter": "season_filter === 'All' || datum.season_type === season_filter"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "circle",
        "opacity": 0.78,
        "stroke": "#faf7f2",
        "strokeWidth": 0.8,
        "clip": true
      },
      "encoding": {
        "x": {
          "field": "year_num",
          "type": "quantitative",
          "axis": {
            "title": "Year",
            "format": "d",
            "tickCount": 9
          },
          "scale": {
            "zero": false,
            "domain": [
              1990,
              2025
            ]
          }
        },
        "y": {
          "field": "yield_t_ha",
          "type": "quantitative",
          "axis": {
            "title": "Yield (t/ha)"
          },
          "scale": {
            "zero": false
          }
        },
        "size": {
          "field": "area_kha",
          "type": "quantitative",
          "scale": {
            "range": [
              35,
              520
            ]
          },
          "legend": {
            "title": "Area ('000 ha)",
            "format": ",.0f"
          }
        },
        "color": {
          "field": "season_type",
          "type": "nominal",
          "scale": {
            "domain": [
              "Drought year",
              "Good season"
            ],
            "range": [
              "#D55E00",
              "#56B4E9"
            ]
          },
          "legend": {
            "title": "Season type"
          }
        },
        "tooltip": [
          {
            "field": "year",
            "type": "nominal",
            "title": "Season"
          },
          {
            "field": "area_kha",
            "type": "quantitative",
            "title": "Area ('000 ha)",
            "format": ",.0f"
          },
          {
            "field": "yield_t_ha",
            "type": "quantitative",
            "title": "Yield (t/ha)",
            "format": ".2f"
          },
          {
            "field": "prod_kt",
            "type": "quantitative",
            "title": "Production (kt)",
            "format": ",.0f"
          },
          {
            "field": "season_type",
            "type": "nominal",
            "title": "Season type"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "regression": "yield_t_ha",
          "on": "year_num"
        }
      ],
      "mark": {
        "type": "line",
        "color": "#0072B2",
        "strokeDash": [
          6,
          3
        ],
        "strokeWidth": 2,
        "opacity": 0.85,
        "clip": true
      },
      "encoding": {
        "x": {
          "field": "year_num",
          "type": "quantitative"
        },
        "y": {
          "field": "yield_t_ha",
          "type": "quantitative"
        }
      }
    },
    {
      "transform": [
        {
          "regression": "yield_t_ha",
          "on": "year_num"
        },
        {
          "window": [
            {
              "op": "max",
              "field": "year_num",
              "as": "x_max"
            }
          ],
          "frame": [
            null,
            null
          ]
        },
        {
          "filter": "datum.year_num === datum.x_max"
        }
      ],
      "mark": {
        "type": "text",
        "align": "right",
        "dx": -6,
        "dy": -10,
        "fontSize": 9,
        "fontStyle": "italic",
        "color": "#0072B2"
      },
      "encoding": {
        "x": {
          "field": "year_num",
          "type": "quantitative"
        },
        "y": {
          "field": "yield_t_ha",
          "type": "quantitative"
        },
        "text": {
          "value": "Trend"
        }
      }
    }
  ],
  "config": {
    "background": null,
    "font": "DM Sans",
    "axis": {
      "labelFont": "DM Sans",
      "titleFont": "DM Sans",
      "labelFontSize": 12,
      "titleFontSize": 13,
      "gridColor": "#e8e0d4",
      "gridOpacity": 0.7,
      "domainColor": "#c8bfb0",
      "tickColor": "#c8bfb0",
      "labelColor": "#6b6a62",
      "titleColor": "#3a3a35"
    },
    "legend": {
      "labelFont": "DM Sans",
      "titleFont": "DM Sans",
      "labelFontSize": 12,
      "titleFontSize": 13,
      "labelColor": "#6b6a62",
      "titleColor": "#3a3a35"
    },
    "title": {
      "font": "Playfair Display",
      "fontSize": 14,
      "color": "#1a2e24"
    },
    "view": {
      "stroke": null
    }
  }
}
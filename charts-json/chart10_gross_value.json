{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 270,
  "data": {
    "url": "data/gross_value_production.json"
  },
  "transform": [
    {
      "filter": "datum.series === 'Total' || datum.series === 'Crops' || datum.series === 'Livestock products' || datum.series === 'Meat & slaughter'"
    },
    {
      "calculate": "toNumber(substring(datum.year,0,4))",
      "as": "year_num"
    }
  ],
  "mark": {
    "type": "line",
    "strokeWidth": 2.2,
    "point": false
  },
  "encoding": {
    "x": {
      "field": "year_num",
      "type": "quantitative",
      "axis": {
        "title": "Year",
        "format": "d",
        "tickCount": 8
      }
    },
    "y": {
      "field": "value",
      "type": "quantitative",
      "axis": {
        "title": "Value ($M)",
        "format": ",.0f"
      }
    },
    "color": {
      "field": "series",
      "type": "nominal",
      "scale": {
        "domain": [
          "Total",
          "Crops",
          "Livestock products",
          "Meat & slaughter"
        ],
        "range": [
          "#444444",
          "#E69F00",
          "#56B4E9",
          "#D55E00"
        ]
      },
      "legend": {
        "title": "Category",
        "orient": "bottom",
        "titlePadding": 25
      }
    },
    "strokeDash": {
      "field": "series",
      "type": "nominal",
      "scale": {
        "domain": [
          "Total",
          "Crops",
          "Livestock products",
          "Meat & slaughter"
        ],
        "range": [
          [
            5,
            3
          ],
          [
            0,
            0
          ],
          [
            0,
            0
          ],
          [
            0,
            0
          ]
        ]
      },
      "legend": null
    },
    "tooltip": [
      {
        "field": "year",
        "type": "nominal",
        "title": "Year"
      },
      {
        "field": "series",
        "type": "nominal",
        "title": "Category"
      },
      {
        "field": "value",
        "type": "quantitative",
        "title": "Value ($M)",
        "format": ",.0f"
      }
    ]
  },
  "config": {
    "background": null,
    "font": "DM Sans",
    "axis": {
      "labelFont": "DM Sans",
      "titleFont": "DM Sans",
      "labelFontSize": 12,
      "titleFontSize": 13,
      "gridColor": "#e8e0d4",
      "gridOpacity": 0.7,
      "domainColor": "#c8bfb0",
      "tickColor": "#c8bfb0",
      "labelColor": "#6b6a62",
      "titleColor": "#3a3a35"
    },
    "legend": {
      "labelFont": "DM Sans",
      "titleFont": "DM Sans",
      "labelFontSize": 12,
      "titleFontSize": 13,
      "labelColor": "#6b6a62",
      "titleColor": "#3a3a35"
    },
    "title": {
      "font": "Playfair Display",
      "fontSize": 14,
      "color": "#1a2e24"
    },
    "view": {
      "stroke": null
    }
  }
}